---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <img src={guide.data.heroImage} class="w-full h-[400px] object-cover rounded-2xl shadow-lg mb-8" alt={guide.data.title} />
    
    <div class="flex items-center gap-4 mb-6">
      <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-bold uppercase">{guide.data.type}</span>
      <span class="text-gray-500 text-sm">Destino: <span class="capitalize font-semibold">{guide.data.destination}</span></span>
    </div>

    <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-8 leading-tight">
      {guide.data.title}
    </h1>

    <div class="prose prose-lg prose-blue max-w-none">
      <Content />
    </div>

    {guide.data.affiliateLink && (
      <div class="mt-12 bg-yellow-50 border-2 border-yellow-200 p-8 rounded-2xl text-center">
        <h3 class="text-2xl font-bold mb-4">Planeje sua visita!</h3>
        <p class="mb-6">Garanta seus ingressos e evite filas em Gramado.</p>
        <a href={guide.data.affiliateLink} target="_blank" class="bg-blue-700 text-white font-bold py-4 px-10 rounded-full hover:bg-blue-800 transition-colors inline-block">
          Comprar Ingressos Oficiais
        </a>
      </div>
    )}
  </article>
</Layout>
