---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await guide.render();

// BUSCA OUTROS POSTS DO MESMO DESTINO (Filtrando o atual)
const allGuides = await getCollection('guides');
const relatedPosts = allGuides
  .filter(p => p.slug !== guide.slug && p.data.destination === guide.data.destination)
  .slice(0, 3);
---

<Layout title={guide.data.title}>
  <article class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide">{guide.data.type} em <span class="capitalize">{guide.data.destination}</span></span>
    
    <h1 class="text-3xl md:text-5xl font-extrabold mb-6 mt-3 leading-tight text-gray-900 drop-shadow-sm font-serif">
      {guide.data.title}
    </h1>
    
    <img src={guide.data.heroImage} class="w-full h-72 md:h-[450px] object-cover rounded-2xl shadow-xl mb-12" alt={guide.data.title} />

    <div class="prose prose-lg prose-blue max-w-none text-gray-800 leading-relaxed font-sans prose-img:rounded-xl prose-headings:font-serif">
      <Content />
    </div>

    {relatedPosts.length > 0 && (
      <div class="border-t border-gray-200 mt-20 pt-16">
        <h3 class="text-2xl md:text-3xl font-black mb-10 text-gray-900 uppercase italic tracking-tighter">Leia Também</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map(post => (
            <a href={`/guia/${post.slug}`} class="block group">
              <div class="bg-white rounded-xl shadow-md overflow-hidden group-hover:shadow-2xl transition-all flex flex-col h-full">
                <img src={post.data.heroImage} class="w-full h-40 object-cover" alt={post.data.title} />
                <div class="p-5 flex-grow">
                  <span class="text-[10px] font-bold uppercase text-blue-600">{post.data.type}</span>
                  <h4 class="font-bold text-base mt-1 leading-snug text-gray-800 group-hover:text-blue-700 transition line-clamp-2">
                    {post.data.title}
                  </h4>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>
