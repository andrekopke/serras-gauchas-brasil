---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}
const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <article class="max-w-2xl mx-auto px-6 py-20 md:py-32 font-sans text-gray-700 antialiased">
    
    <div class="mb-8">
        <span class="bg-blue-600 text-white px-3 py-1 rounded-sm text-[10px] font-bold uppercase tracking-[0.15em] leading-none inline-block">
            {guide.data.type}
        </span>
    </div>
    
    <h1 class="text-3xl md:text-4xl font-extrabold mb-12 leading-tight text-gray-900 tracking-tight">
      {guide.data.title}
    </h1>
    
    <div class="mb-24">
        <img src={guide.data.heroImage} class="w-full h-auto shadow-sm" alt={guide.data.title} />
    </div>

    <div class="prose prose-lg max-w-none 
                prose-slate
                prose-p:leading-9 prose-p:mb-16 prose-p:text-gray-600
                prose-headings:text-gray-900 prose-headings:font-bold
                prose-h2:text-2xl md:text-3xl prose-h2:mt-32 prose-h2:mb-12 prose-h2:tracking-tight
                prose-h3:text-xl md:text-2xl prose-h3:mt-16 prose-h3:mb-8
                prose-li:mb-6 prose-ul:mb-16
                prose-hr:border-t prose-hr:border-gray-200 prose-hr:my-24
                prose-blockquote:bg-[#f0f7ff] prose-blockquote:border-l-4 prose-blockquote:border-blue-600 prose-blockquote:p-10 prose-blockquote:rounded-r-md prose-blockquote:not-italic prose-blockquote:my-20 prose-blockquote:text-blue-900 prose-blockquote:shadow-sm">
      <Content />
    </div>

  </article>
</Layout>
