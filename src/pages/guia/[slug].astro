---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}
const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <article class="max-w-2xl mx-auto px-6 py-12 md:py-24 font-sans text-gray-700 antialiased">
    
    <div class="mb-4 flex justify-center md:justify-start">
        <span class="bg-blue-600 text-white px-3 py-1 rounded-sm text-[10px] font-bold uppercase tracking-widest leading-none">
            {guide.data.type}
        </span>
    </div>
    
    <h1 class="text-2xl md:text-3xl font-extrabold mb-8 leading-tight text-gray-950 tracking-tight text-center md:text-left">
      {guide.data.title}
    </h1>
    
    <div class="mb-16">
        <img src={guide.data.heroImage} class="w-full h-auto rounded-sm shadow-sm border border-gray-100" alt={guide.data.title} />
    </div>

    <div class="prose prose-base md:prose-lg max-w-none 
                text-gray-700 font-sans
                prose-p:leading-8 prose-p:mb-12
                prose-headings:text-gray-900 prose-headings:font-bold prose-headings:font-sans
                prose-h2:text-xl md:text-2xl prose-h2:mt-24 prose-h2:mb-8 prose-h2:border-b prose-h2:border-gray-100 prose-h2:pb-3
                prose-h3:text-lg md:text-xl prose-h3:mt-12 prose-h3:mb-4
                prose-li:mb-4 prose-ul:mb-12
                prose-hr:border-t prose-hr:border-gray-200 prose-hr:my-20
                prose-blockquote:bg-blue-50 prose-blockquote:border-l-4 prose-blockquote:border-blue-600 prose-blockquote:p-8 prose-blockquote:rounded-r-md prose-blockquote:not-italic prose-blockquote:my-16 prose-blockquote:text-blue-900 shadow-sm">
      <Content />
    </div>

  </article>
</Layout>
