---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}
const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <article class="max-w-2xl mx-auto px-6 py-10 md:py-16 font-sans text-gray-700 antialiased">
    
    <div class="mb-4">
        <span class="bg-blue-600 text-white px-2 py-0.5 rounded-sm text-[10px] font-bold uppercase tracking-wider">
            {guide.data.type}
        </span>
    </div>
    
    <h1 class="text-2xl md:text-3xl font-bold mb-8 leading-tight text-gray-900 tracking-tight">
      {guide.data.title}
    </h1>
    
    <div class="mb-12">
        <img src={guide.data.heroImage} class="w-full h-auto shadow-sm border border-gray-100" alt={guide.data.title} />
    </div>

    <div class="prose prose-base md:prose-lg max-w-none 
                prose-slate
                prose-p:leading-8 prose-p:mb-10 prose-p:text-gray-600
                prose-headings:text-gray-900 prose-headings:font-bold prose-headings:font-sans
                prose-h2:text-xl md:text-2xl prose-h2:mt-16 prose-h2:mb-6
                prose-h3:text-lg md:text-xl prose-h3:mt-10 prose-h3:mb-4
                prose-li:mb-3 prose-ul:mb-10
                prose-hr:border-t prose-hr:border-gray-200 prose-hr:my-16
                prose-blockquote:bg-blue-50 prose-blockquote:border-l-4 prose-blockquote:border-blue-600 prose-blockquote:p-8 prose-blockquote:rounded-r-sm prose-blockquote:not-italic prose-blockquote:my-14 prose-blockquote:text-blue-900">
      <Content />
    </div>

  </article>
</Layout>
