---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}
const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <article class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    
    <div class="mb-4">
        <span class="text-blue-600 text-[11px] font-bold uppercase tracking-[0.2em]">
            {guide.data.type}
        </span>
    </div>
    
    <h1 class="text-3xl md:text-4xl font-extrabold mb-8 leading-tight text-gray-900 font-sans tracking-tight">
      {guide.data.title}
    </h1>
    
    <div class="mb-16">
        <img src={guide.data.heroImage} class="w-full h-auto rounded-lg shadow-sm border border-gray-100" alt={guide.data.title} />
    </div>

    <div class="prose prose-lg md:prose-xl prose-slate max-w-none 
                text-gray-700 font-sans
                prose-p:leading-8 prose-p:mb-10
                prose-headings:text-gray-900 prose-headings:font-bold
                prose-h2:text-2xl md:text-3xl prose-h2:mt-20 prose-h2:mb-8
                prose-h3:text-xl md:text-2xl prose-h3:mt-12 prose-h3:mb-6
                prose-li:mb-4 prose-ul:mb-10
                prose-hr:border-gray-200 prose-hr:my-16
                prose-blockquote:bg-blue-50 prose-blockquote:border-l-4 prose-blockquote:border-blue-600 prose-blockquote:p-8 prose-blockquote:rounded-r-xl prose-blockquote:not-italic prose-blockquote:my-16 prose-blockquote:text-blue-900">
      <Content />
    </div>

  </article>
</Layout>
