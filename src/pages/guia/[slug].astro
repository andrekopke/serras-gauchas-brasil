---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}
const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <article class="max-w-2xl mx-auto px-4 py-10 md:py-20">
    
    <div class="mb-6 flex justify-center md:justify-start">
        <span class="bg-blue-600 text-white px-3 py-1 rounded text-[10px] font-bold uppercase tracking-widest">
            {guide.data.type}
        </span>
    </div>
    
    <h1 class="text-2xl md:text-4xl font-black mb-10 leading-tight text-gray-900 font-sans tracking-tight text-center md:text-left">
      {guide.data.title}
    </h1>
    
    <div class="mb-20">
        <img src={guide.data.heroImage} class="w-full h-auto rounded-2xl shadow-md border border-gray-100" alt={guide.data.title} />
    </div>

    <div class="prose prose-lg md:prose-xl prose-blue max-w-none 
                text-gray-800 
                prose-p:leading-8 prose-p:mb-10
                prose-headings:text-gray-900 prose-headings:font-bold
                prose-h2:text-2xl md:text-3xl prose-h2:mt-24 prose-h2:mb-10 prose-h2:border-b prose-h2:pb-4
                prose-h3:text-xl md:text-2xl prose-h3:mt-16 prose-h3:mb-6
                prose-li:mb-5 prose-ul:mb-12
                prose-blockquote:bg-yellow-50 prose-blockquote:border-yellow-400 prose-blockquote:p-8 prose-blockquote:rounded-2xl prose-blockquote:not-italic prose-blockquote:my-16
                prose-img:my-16 prose-img:rounded-2xl">
      <Content />
    </div>

  </article>
</Layout>
