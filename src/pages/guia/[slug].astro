---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}
const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <article class="max-w-[720px] mx-auto px-6 py-16 md:py-24 font-sans antialiased text-[#333]">
    
    <div class="mb-6">
        <span class="bg-[#0055ff] text-white px-2 py-0.5 rounded-sm text-[10px] font-bold uppercase tracking-widest leading-none">
            {guide.data.type}
        </span>
    </div>
    
    <h1 class="text-[32px] md:text-[40px] font-bold mb-10 leading-[1.2] text-black tracking-tight">
      {guide.data.title}
    </h1>
    
    <div class="mb-20">
        <img src={guide.data.heroImage} class="w-full h-auto shadow-sm border border-gray-100" alt={guide.data.title} />
    </div>

    <div class="content-body prose prose-neutral max-w-none">
      <Content />
    </div>

  </article>
</Layout>

<style is:global>
  /* FORÇANDO O ESPAÇAMENTO "BREATHING SPACE" */
  
  /* 1. Espaço gigante entre parágrafos */
  .content-body p {
    margin-bottom: 40px !important;
    line-height: 1.85 !important;
    font-size: 18px !important;
    color: #444 !important;
  }

  /* 2. Espaço antes e depois dos títulos principais (H2) */
  .content-body h2 {
    margin-top: 80px !important;
    margin-bottom: 30px !important;
    font-size: 28px !important;
    font-weight: 700 !important;
    color: #000 !important;
    border-bottom: 1px solid #eee;
    padding-bottom: 10px;
  }

  /* 3. Espaço nos subtítulos (H3) */
  .content-body h3 {
    margin-top: 50px !important;
    margin-bottom: 20px !important;
    font-size: 22px !important;
    font-weight: 700 !important;
  }

  /* 4. O Diferencial: Links em Azul MD */
  .content-body a {
    color: #0055ff !important;
    text-decoration: none !important;
    font-weight: 600 !important;
  }
  .content-body a:hover {
    text-decoration: underline !important;
  }

  /* 5. Linhas divisórias com muito espaço */
  .content-body hr {
    margin: 80px 0 !important;
    border: 0;
    border-top: 1px solid #eee !important;
  }

  /* 6. A Caixa Azul de Destaque */
  .content-body blockquote {
    background-color: #f0f7ff !important;
    border-left: 4px solid #0055ff !important;
    padding: 30px !important;
    margin: 60px 0 !important;
    border-radius: 0 8px 8px 0;
    font-style: normal !important;
  }
</style>
