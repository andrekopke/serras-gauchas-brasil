---
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" /><meta name="viewport" content="width=device-width" /><title>{title}</title>
	</head>
	<body class="bg-gray-50 font-sans text-gray-900 flex flex-col min-h-screen">
		<header class="bg-blue-700 text-white shadow-md">
			<nav class="container mx-auto px-4 py-3 flex justify-between items-center">
				<a href="/" class="text-xl font-black italic uppercase">GUIA <span class="text-yellow-400">SERRAS</span></a>
				<div class="hidden md:flex space-x-6 text-xs font-bold uppercase tracking-wider">
					<a href="/guia/passagens" class="hover:text-yellow-300">✈️ Passagens</a>
					<a href="/guia/hoteis" class="hover:text-yellow-300">🏨 Hotéis</a>
					<a href="/guia/ingressos" class="hover:text-yellow-300">🎫 Ingressos</a>
				</div>
			</nav>
            <div class="bg-white border-b overflow-x-auto text-center">
                <div class="container mx-auto flex justify-center p-3 gap-8 min-w-[500px]">
                    <a href="/guia/o-que-fazer" class="flex flex-col items-center group">
                        <span class="text-2xl">🎢</span><span class="text-[9px] font-bold text-gray-600 mt-1 uppercase">O que fazer</span>
                    </a>
                    <a href="/guia/onde-ficar" class="flex flex-col items-center group">
                        <span class="text-2xl">🏨</span><span class="text-[9px] font-bold text-gray-600 mt-1 uppercase">Onde Ficar</span>
                    </a>
                    <a href="/guia/onde-comer" class="flex flex-col items-center group">
                        <span class="text-2xl">🍽️</span><span class="text-[9px] font-bold text-gray-600 mt-1 uppercase">Onde Comer</span>
                    </a>
                    <a href="/descontos" class="flex flex-col items-center group">
                        <span class="text-2xl">🎟️</span><span class="text-[9px] font-bold text-yellow-600 mt-1 uppercase">Cupons</span>
                    </a>
                </div>
            </div>
		</header>
		
		<main class="flex-grow"><slot /></main>

		<footer class="bg-blue-900 text-white mt-16 py-12 text-sm">
			<div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-8">
				<div>
					<a href="/" class="text-2xl font-black italic uppercase text-white">GUIA <span class="text-yellow-400">SERRAS</span></a>
					<p class="text-gray-300 mt-4 text-xs leading-relaxed">O seu portal independente de turismo na Serra Gaúcha. Dicas reais de quem vive e ama Gramado e Canela.</p>
				</div>
				<div>
					<h5 class="font-bold text-yellow-400 uppercase mb-4 tracking-wider text-xs">Navegue no Guia</h5>
					<ul class="space-y-2 text-gray-200 text-xs">
						<li><a href="/guia/o-que-fazer" class="hover:text-yellow-300">Atrações</a></li>
						<li><a href="/guia/onde-ficar" class="hover:text-yellow-300">Onde Ficar</a></li>
						<li><a href="/guia/onde-comer" class="hover:text-yellow-300">Onde Comer</a></li>
						<li><a href="/descontos" class="hover:text-yellow-300 font-bold">Cupons de Desconto</a></li>
					</ul>
				</div>
				<div>
					<h5 class="font-bold text-yellow-400 uppercase mb-4 tracking-wider text-xs">Informações</h5>
					<ul class="space-y-2 text-gray-200 text-xs">
						<li><a href="/quem-somos" class="hover:text-yellow-300">Quem Somos</a></li>
						<li><a href="/contato" class="hover:text-yellow-300">Contato</a></li>
						<li><a href="/politica-de-privacidade" class="hover:text-yellow-300 font-semibold text-gray-300">Política de Privacidade</a></li>
						<li><a href="/termos-de-uso" class="hover:text-yellow-300 text-gray-300">Termos de Uso</a></li>
					</ul>
				</div>
				<div>
					<h5 class="font-bold text-yellow-400 uppercase mb-4 tracking-wider text-xs">Siga-nos</h5>
					<div class="flex space-x-4 text-xl">
						<a href="#" class="hover:text-yellow-300">📷</a> <a href="#" class="hover:text-yellow-300">👍</a> <a href="#" class="hover:text-yellow-300">🐦</a>
					</div>
				</div>
			</div>
			<div class="container mx-auto px-4 mt-10 pt-6 border-t border-blue-800 text-center text-gray-400 text-xs">
				&copy; 2026 Guia Gramado e Canela. Todos os direitos reservados.
			</div>
		</footer>
	</body>
</html>
