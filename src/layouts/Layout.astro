---
import { getCollection } from 'astro:content';

interface Props { title: string; }
const { title } = Astro.props;

const posts = await getCollection('guides');

const orderedPosts = posts.sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder
);

const firstPosts = orderedPosts.slice(0, 6);
const restPosts = orderedPosts.slice(6);
---

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Guia Gramado e Canela</title>
</head>

<body class="bg-gray-50 font-sans text-gray-900 flex flex-col min-h-screen">

<header class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
        <a href="/" class="text-2xl font-black italic tracking-tighter uppercase">
            GUIA <span class="text-yellow-400 font-extrabold">SERRAS</span>
        </a>

        <div class="hidden lg:flex space-x-5 text-[11px] font-bold uppercase tracking-wide">
            <a href="/guia/passagens" class="hover:text-yellow-400">✈️ Passagens</a>
            <a href="/guia/hoteis" class="hover:text-yellow-300">🏨 Hotéis</a>
            <a href="/guia/pacotes" class="hover:text-yellow-300">📦 Pacotes</a>
            <a href="/guia/seguro-viagem" class="hover:text-yellow-300">🛡️ Seguro</a>
            <a href="/guia/aluguel-carros" class="hover:text-yellow-300">🚗 Carros</a>
            <a href="/descontos" class="bg-yellow-500 text-blue-900 px-3 py-1 rounded-full hover:bg-yellow-400 transition-colors">🎟️ Cupons</a>
        </div>
    </div>

    <div class="bg-white border-b border-gray-200 overflow-x-auto shadow-sm">
        <div class="container mx-auto flex justify-between md:justify-center p-3 gap-6 md:gap-12 min-w-[600px]">
            <a href="/guia/o-que-fazer" class="flex flex-col items-center"><span class="text-xl">🎡</span><span class="text-[9px] font-extrabold text-gray-500 mt-1 uppercase">O que Fazer</span></a>
            <a href="/guia/onde-ficar" class="flex flex-col items-center"><span class="text-xl">🛌</span><span class="text-[9px] font-extrabold text-gray-500 mt-1 uppercase">Onde Ficar</span></a>
            <a href="/guia/onde-comer" class="flex flex-col items-center"><span class="text-xl">🍽️</span><span class="text-[9px] font-extrabold text-gray-500 mt-1 uppercase">Onde Comer</span></a>
            <a href="/guia/como-chegar" class="flex flex-col items-center"><span class="text-xl">🚗</span><span class="text-[9px] font-extrabold text-gray-500 mt-1 uppercase">Como Chegar</span></a>
            <a href="/guia/roteiros" class="flex flex-col items-center"><span class="text-xl">🗺️</span><span class="text-[9px] font-extrabold text-gray-500 mt-1 uppercase">Roteiros</span></a>
            <a href="/guia/natal-luz" class="flex flex-col items-center"><span class="text-xl">🎄</span><span class="text-[9px] font-extrabold text-red-600 mt-1 uppercase">Natal Luz</span></a>
        </div>
    </div>
</header>

<main class="flex-grow">
    <slot />

    <section class="container mx-auto px-4 mt-16">

        <div class="bg-white p-6 rounded-xl shadow mb-8 text-center">
            <h2 class="text-xl md:text-2xl font-bold">
                Veja mais dicas especiais nos posts abaixo
            </h2>
        </div>

        <div id="posts-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

            {firstPosts.map((post) => (
                <a href={`/guia/${post.slug}/`} class="block group">

                    <div class="bg-white rounded-xl overflow-hidden shadow hover:shadow-xl transition duration-300 group-hover:-translate-y-1">

                        <img
                          src={post.data.heroImage}
                          alt={post.data.title}
                          loading="lazy"
                          class="w-full h-48 object-cover"
                        />

                        <div class="p-4">
                            <h3 class="font-bold text-lg mb-2 group-hover:text-blue-700 transition">
                                {post.data.title}
                            </h3>

                            <p class="text-sm text-gray-600">
                                {post.data.description}
                            </p>
                        </div>

                    </div>

                </a>
            ))}

        </div>

        <!-- 🔥 OBSERVER -->
        <div id="sentinel" class="h-10"></div>

        <div id="loader" class="text-center py-10 text-gray-500">
            Carregando mais posts...
        </div>

    </section>

</main>

<footer class="bg-gray-900 text-white mt-16 pt-16 pb-8">
    <div class="container mx-auto px-4">

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">

            <div>
                <h4 class="text-xl font-black italic uppercase">
                    GUIA <span class="text-yellow-400">SERRAS</span>
                </h4>
            </div>

            <div>
                <h5 class="text-sm font-bold uppercase tracking-widest text-yellow-400 mb-6">
                    Informações
                </h5>
                <ul class="space-y-3 text-sm text-gray-300">
                    <li><a href="/sobre" class="hover:text-white transition">Quem Somos</a></li>
                    <li><a href="/contato" class="hover:text-white transition">Contato / Anuncie</a></li>
                    <li><a href="/politica-de-privacidade" class="hover:text-white transition">Política de Privacidade</a></li>
                    <li><a href="/termos-de-uso" class="hover:text-white transition">Termos de Uso</a></li>
                </ul>
            </div>

        </div>

        <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500">
            <p>&copy; 2026 Guia Gramado e Canela. Todos os direitos reservados.</p>
            <p class="mt-4 md:mt-0">Desenvolvido para viajantes com ❤️</p>
        </div>

    </div>
</footer>

<script>
const restPosts = JSON.parse(`${
JSON.stringify(
restPosts.map(post => ({
slug: post.slug,
title: post.data.title,
description: post.data.description,
heroImage: post.data.heroImage
}))
)
}`);

let index = 0;
const perLoad = 6;

const grid = document.getElementById('posts-grid');
const loader = document.getElementById('loader');
const sentinel = document.getElementById('sentinel');

function loadMore() {
if (index >= restPosts.length) return;

const nextPosts = restPosts.slice(index, index + perLoad);

nextPosts.forEach(post => {
const card = document.createElement('a');
card.href = `/guia/${post.slug}/`;
card.className = "block group";

card.innerHTML = `
<div class="bg-white rounded-xl overflow-hidden shadow hover:shadow-xl transition duration-300 group-hover:-translate-y-1">
<img src="${post.heroImage}" class="w-full h-48 object-cover" loading="lazy"/>
<div class="p-4">
<h3 class="font-bold text-lg mb-2 group-hover:text-blue-700">${post.title}</h3>
<p class="text-sm text-gray-600">${post.description}</p>
</div>
</div>
`;

grid.appendChild(card);
});

index += perLoad;

if (index >= restPosts.length) {
loader.innerText = "Fim dos posts";
observer.disconnect();
}
}

// 🔥 OBSERVER (PROFISSIONAL)
const observer = new IntersectionObserver(entries => {
if (entries[0].isIntersecting) {
loadMore();
}
}, { rootMargin: "200px" });

observer.observe(sentinel);

// 🔥 FALLBACK (caso browser antigo)
window.addEventListener('scroll', () => {
if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 200) {
loadMore();
}
});
</script>

</body>
</html>
