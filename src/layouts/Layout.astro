---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Guia completo de viagem para Gramado, Canela e Serras Gaúchas" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | Guia Gramado e Canela</title>
	</head>
	<body class="bg-gray-50 font-sans text-gray-900">
		<header class="bg-blue-700 text-white shadow-md">
			<nav class="container mx-auto px-4 py-4 flex justify-between items-center">
				<a href="/" class="text-2xl font-bold tracking-tight">Guia <span class="text-yellow-400">Serras</span></a>
				<div class="space-x-6 hidden md:block">
					<a href="#" class="hover:text-yellow-400">Destinos</a>
					<a href="#" class="hover:text-yellow-400">Atrações</a>
					<a href="#" class="hover:text-yellow-400">Hospedagem</a>
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="bg-gray-800 text-white mt-12 py-10">
			<div class="container mx-auto px-4 text-center">
				<p class="mb-4">© 2026 Guia Gramado e Canela - O seu portal das Serras Gaúchas</p>
				<div class="text-gray-400 text-sm">
					Feito para viajantes, por viajantes.
				</div>
			</div>
		</footer>
	</body>
</html>
